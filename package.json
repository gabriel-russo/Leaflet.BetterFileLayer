{
  "name": "leaflet-better-filelayer",
  "version": "2.0.0",
  "description": "Load spatialized files into leaflet using the HTML FileReader API",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/leaflet.betterfilelayer.js",
  "module": "./dist/leaflet.betterfilelayer.js",
  "types": "./dist/types.d.ts",
  "styles": "./dist/leaflet.betterfilelayer.css",
  "exports": {
    ".": {
      "types": "./dist/types.d.ts",
      "import": "./dist/leaflet.betterfilelayer.js",
      "require": "./dist/leaflet.betterfilelayer.js",
      "default": "./dist/leaflet.betterfilelayer.js"
    },
    "./dist/leaflet.betterfilelayer.css": "./dist/leaflet.betterfilelayer.css"
  },
  "scripts": {
    "dev": "vite --port 3000",
    "test": "jest",
    "declaration": "tsc -p tsconfig.declaration.ts",
    "build": "vite build && npm run declaration",
    "pack": "npm run build && npm pack",
    "lint": "eslint src/",
    "style": "prettier --write \"src/**/*.{ts,js,css}\" --log-level=warn"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gabriel-russo/Leaflet.BetterFileLayer.git"
  },
  "keywords": [
    "leaflet",
    "leaflet file",
    "formats",
    "kml",
    "csv",
    "gpx",
    "geojson",
    "kml",
    "leaflet",
    "maps",
    "gpx",
    "wkt",
    "osm",
    "polyline",
    "topojson",
    "format",
    "converter"
  ],
  "author": "Gabriel Russo",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/gabriel-russo/Leaflet.BetterFileLayer/issues"
  },
  "homepage": "https://github.com/gabriel-russo/Leaflet.BetterFileLayer",
  "peerDependencies": {
    "leaflet": ">=2.0.0-alpha.1"
  },
  "dependencies": {
    "@mapbox/polyline": "^1.2.1",
    "@mapbox/togeojson": "^0.16.2",
    "brfs": "^2.0.2",
    "buffer": "^6.0.3",
    "csv2geojson": "^5.1.2",
    "jszip": "^3.10.1",
    "shpjs": "^6.2.0",
    "topojson-client": "^3.1.0",
    "wellknown": "^0.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@jest/globals": "^30.2.0",
    "@types/geojson": "^7946.0.16",
    "@types/jest": "^30.0.0",
    "@types/leaflet": "^1.9.21",
    "@types/mapbox__polyline": "^1.0.5",
    "@types/shpjs": "^3.4.7",
    "@types/topojson-client": "^3.1.5",
    "@types/wellknown": "^0.5.8",
    "eslint": "^10.0.2",
    "jest": "^30.2.0",
    "jest-fixed-jsdom": "^0.0.11",
    "prettier": "^3.8.1",
    "terser": "^5.46.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1"
  },
  "prettier": {
    "trailingComma": "es5",
    "tabWidth": 2,
    "semi": true,
    "singleQuote": true
  }
}
